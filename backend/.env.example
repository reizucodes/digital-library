# --- Local development (SQLite) ---
DATABASE_URL=sqlite:///./data/library.db

# --- Production (Neon PostgreSQL) ---
# Replace with your Neon connection string from the Neon dashboard.
# Format: postgresql://user:password@host/dbname?sslmode=require
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# CORS origins — comma-separated list of allowed frontend URLs.
# Local dev:
CORS_ORIGINS=http://localhost:5173
# Production (add your Vercel URL alongside localhost if needed):
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Secret key used for token signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production
